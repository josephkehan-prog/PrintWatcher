    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="PipRoot" Width="10" Height="10">
        <Ellipse
            x:Name="Pip"
            Width="10"
            Height="10"
            Fill="{ThemeResource OkBrush}" />
    </Grid>
</UserControl>
