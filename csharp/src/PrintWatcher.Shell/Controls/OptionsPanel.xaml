<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PrintWatcher.Shell.Controls.OptionsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PrintWatcher.Shell.ViewModels">
    <UserControl.Resources>
        <Style x:Key="OptionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{ThemeResource MutedBrush}" />
            <Setter Property="CharacterSpacing" Value="80" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
    </UserControl.Resources>

    <Border
        Background="{ThemeResource PanelBrush}"
        CornerRadius="14"
        Padding="20,16">
        <StackPanel Spacing="12">
            <TextBlock
                Text="PRINT OPTIONS"
                Style="{StaticResource OptionLabelStyle}" />
            <Grid ColumnSpacing="16" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="2">
                    <TextBlock Text="PRINTER" Style="{StaticResource OptionLabelStyle}" />
                    <ComboBox
                        ItemsSource="{x:Bind ViewModel.Printers, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.Printer, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="Default printer" />
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="2">
                    <TextBlock Text="COPIES" Style="{StaticResource OptionLabelStyle}" />
                    <NumberBox
                        Value="{x:Bind ViewModel.CopiesDouble, Mode=TwoWay}"
                        Minimum="1"
                        Maximum="99"
                        SpinButtonPlacementMode="Inline" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="2">
                    <TextBlock Text="SIDES" Style="{StaticResource OptionLabelStyle}" />
                    <ComboBox
                        ItemsSource="{x:Bind vm:OptionsViewModel.SidesOptions}"
                        SelectedItem="{x:Bind ViewModel.Sides, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="(printer default)" />
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="2">
                    <TextBlock Text="COLOR" Style="{StaticResource OptionLabelStyle}" />
                    <ComboBox
                        ItemsSource="{x:Bind vm:OptionsViewModel.ColorOptions}"
                        SelectedItem="{x:Bind ViewModel.Color, Mode=TwoWay}"
                        HorizontalAlignment="Stretch"
                        PlaceholderText="(printer default)" />
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
