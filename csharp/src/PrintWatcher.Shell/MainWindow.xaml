<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="PrintWatcher.Shell.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Grid>
        <muxc:NavigationView
            x:Name="Nav"
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Dashboard" Tag="dashboard" Icon="Home" IsSelected="True" />
                <muxc:NavigationViewItem Content="History" Tag="history" Icon="List" />
                <muxc:NavigationViewItem Content="Tools" Tag="tools" Icon="Repair" />
                <muxc:NavigationViewItem Content="Settings" Tag="settings" Icon="Setting" />
            </muxc:NavigationView.MenuItems>
            <Grid Padding="32">
                <StackPanel Spacing="12" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock
                        Text="PrintWatcher"
                        FontSize="48"
                        FontWeight="Light" />
                    <TextBlock
                        x:Name="StatusText"
                        Text="Connecting to backend..."
                        Opacity="0.7" />
                </StackPanel>
            </Grid>
        </muxc:NavigationView>
    </Grid>
</Window>
