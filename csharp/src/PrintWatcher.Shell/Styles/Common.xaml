<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="CardCornerRadius">14</x:Double>
    <x:Double x:Key="LabelLetterSpacing">80</x:Double>
    <Thickness x:Key="PageContentPadding">32,24,32,32</Thickness>
    <Thickness x:Key="CardPadding">20,16</Thickness>
    <CornerRadius x:Key="CardRadius">14</CornerRadius>

    <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource MutedBrush}" />
        <Setter Property="CharacterSpacing" Value="80" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Light" />
        <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
    </Style>

    <Style x:Key="GroupCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>

    <Style x:Key="LogTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Consolas, Cascadia Code, monospace" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource LogTextBrush}" />
    </Style>
</ResourceDictionary>
