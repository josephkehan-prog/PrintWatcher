<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PrintWatcher.Shell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Fallback brushes. ThemeService overrides these at app startup; the
                 defaults match the Ocean palette so the designer + the brief flash
                 before Apply() runs both look intentional. -->
            <SolidColorBrush x:Key="BgBrush" Color="#FF006494" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF0582CA" />
            <SolidColorBrush x:Key="LogBgBrush" Color="#FF003E5C" />
            <SolidColorBrush x:Key="TextBrush" Color="#FFE0F2FF" />
            <SolidColorBrush x:Key="MutedBrush" Color="#FFA3C4D9" />
            <SolidColorBrush x:Key="OkBrush" Color="#FF00A6FB" />
            <SolidColorBrush x:Key="ErrBrush" Color="#FF6B8A9C" />
            <SolidColorBrush x:Key="LogTextBrush" Color="#FFE0F2FF" />
            <SolidColorBrush x:Key="BtnHoverBrush" Color="#FF0A96E0" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
