<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PrintWatcher.Shell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Styles/Common.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Neutral fallbacks shown only during the brief flash before
                 ThemeService.Apply() runs. ThemeService overrides every key. -->
            <SolidColorBrush x:Key="BgBrush" Color="#FF101418" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF1B2027" />
            <SolidColorBrush x:Key="LogBgBrush" Color="#FF0C0F13" />
            <SolidColorBrush x:Key="TextBrush" Color="#FFE6EAF0" />
            <SolidColorBrush x:Key="MutedBrush" Color="#FF8A93A0" />
            <SolidColorBrush x:Key="OkBrush" Color="#FF4CC2FF" />
            <SolidColorBrush x:Key="ErrBrush" Color="#FFFF6B6B" />
            <SolidColorBrush x:Key="LogTextBrush" Color="#FFE6EAF0" />
            <SolidColorBrush x:Key="BtnHoverBrush" Color="#FF2A313B" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
