<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PrintWatcher.Shell.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Fallback brushes. ThemeService overrides these at app startup; the
                 defaults match the Ocean palette so the designer + the brief flash
                 before Apply() runs both look intentional. -->
            <SolidColorBrush x:Key="BgBrush" Color="#FF006494" />
            <SolidColorBrush x:Key="PanelBrush" Color="#FF0582CA" />
            <SolidColorBrush x:Key="LogBgBrush" Color="#FF003E5C" />
            <SolidColorBrush x:Key="TextBrush" Color="#FFE0F2FF" />
            <SolidColorBrush x:Key="MutedBrush" Color="#FFA3C4D9" />
            <SolidColorBrush x:Key="OkBrush" Color="#FF00A6FB" />
            <SolidColorBrush x:Key="ErrBrush" Color="#FF6B8A9C" />
            <SolidColorBrush x:Key="LogTextBrush" Color="#FFE0F2FF" />
            <SolidColorBrush x:Key="BtnHoverBrush" Color="#FF0A96E0" />

            <!-- Glass depth resources. Surfaces carry a 1px border whose brush is
                 swapped per palette by ThemeService: fully transparent on the
                 solid themes (so they stay visually borderless), a bright hairline
                 on Glass. The default below is the opaque/no-op case so the
                 designer and the pre-Apply() flash stay borderless. SurfaceShadow
                 is shared; GlassDepth toggles each surface's Z so it only casts
                 under the translucent palette. -->
            <SolidColorBrush x:Key="SurfaceBorderBrush" Color="Transparent" />
            <ThemeShadow x:Key="SurfaceShadow" />

            <!-- Shared type scale. Previously every page redeclared its own copy of
                 these (a 12px caption style appeared 5× under different names, the
                 32px page title was inlined on every page). Centralising them here
                 gives one source of truth and lets a future "Larger text" setting
                 scale typography in one place. -->
            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="32" />
                <Setter Property="FontWeight" Value="Light" />
                <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
            </Style>
            <Style x:Key="CaptionLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="Foreground" Value="{ThemeResource MutedBrush}" />
            </Style>
            <Style x:Key="MonospaceTextStyle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Consolas, Cascadia Code, monospace" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource LogTextBrush}" />
            </Style>

            <!-- Base elevated-surface (card / panel) style. The per-page card styles
                 (StatTileStyle, ToolCardStyle) and the inline panel/log borders all
                 repeated this same set of setters; they now derive from this via
                 BasedOn, or apply it directly and override only what differs (e.g. a
                 LogBgBrush background). GlassDepth.Elevated stays on the element
                 instances (attached-property setters in a Style are brittle in WinUI). -->
            <Style x:Key="CardSurfaceStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource SurfaceBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Shadow" Value="{ThemeResource SurfaceShadow}" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="20,16" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
