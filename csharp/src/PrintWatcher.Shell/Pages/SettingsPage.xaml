<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PrintWatcher.Shell.Controls">

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PageContentPadding}" Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <controls:PageHeader
                Title="Settings"
                Subtitle="{x:Bind ViewModel.StatusLabel, Mode=OneWay}" />

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="THEME" Style="{StaticResource SectionLabelStyle}" />
                    <ComboBox
                        ItemsSource="{x:Bind ViewModel.ThemeKeys}"
                        SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                        MinWidth="220" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="ACCESSIBILITY" Style="{StaticResource SectionLabelStyle}" />
                    <ToggleSwitch
                        Header="Larger text"
                        OffContent="Default"
                        OnContent="Scaled up by 1.15×"
                        IsOn="{x:Bind ViewModel.LargerText, Mode=TwoWay}" />
                    <ToggleSwitch
                        Header="Reduce transparency"
                        OffContent="Mica backdrop on"
                        OnContent="Solid surfaces only"
                        IsOn="{x:Bind ViewModel.ReduceTransparency, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="WATCHER" Style="{StaticResource SectionLabelStyle}" />
                    <ToggleSwitch
                        Header="Hold incoming files"
                        OffContent="Print as soon as files arrive"
                        OnContent="Hold for review on the Pending page"
                        IsOn="{x:Bind ViewModel.HoldMode, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <!--
              Per-printer defaults. Pick a printer; configured sides/color/copies
              fill in only when the user (or a path-token override) hasn't set
              the field explicitly. Saved under preferences.json's
              printer_defaults subkey.
            -->
            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="PRINTER DEFAULTS" Style="{StaticResource SectionLabelStyle}" />
                    <ComboBox
                        Header="Printer"
                        ItemsSource="{x:Bind ViewModel.KnownPrinters}"
                        SelectedItem="{x:Bind ViewModel.PrinterDefaultPrinter, Mode=TwoWay}"
                        MinWidth="260" />
                    <ComboBox
                        Header="Sides"
                        ItemsSource="{x:Bind ViewModel.SidesOptions}"
                        SelectedItem="{x:Bind ViewModel.PrinterDefaultSides, Mode=TwoWay}"
                        MinWidth="180" />
                    <ComboBox
                        Header="Color"
                        ItemsSource="{x:Bind ViewModel.ColorOptions}"
                        SelectedItem="{x:Bind ViewModel.PrinterDefaultColor, Mode=TwoWay}"
                        MinWidth="180" />
                    <NumberBox
                        Header="Copies"
                        Minimum="1"
                        Maximum="99"
                        Value="{x:Bind ViewModel.PrinterDefaultCopies, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            Content="Save defaults"
                            Style="{ThemeResource AccentButtonStyle}"
                            Command="{x:Bind ViewModel.SavePrinterDefaultCommand}" />
                        <Button
                            Content="Clear"
                            Command="{x:Bind ViewModel.ClearPrinterDefaultCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="BACKEND LOG" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Show tail" Command="{x:Bind ViewModel.ShowBackendLogCommand}" />
                    </Grid>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            PlaceholderText="Filter logs (substring)"
                            Text="{x:Bind ViewModel.LogFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{x:Bind ViewModel.LogLevels}"
                            SelectedItem="{x:Bind ViewModel.LogLevel, Mode=TwoWay}"
                            MinWidth="100" />
                    </Grid>
                    <Border
                        Background="{ThemeResource LogBgBrush}"
                        CornerRadius="8"
                        Padding="12"
                        MinHeight="120"
                        MaxHeight="280">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.FilteredLog, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock
                                            Style="{StaticResource LogTextStyle}"
                                            Text="{x:Bind}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
