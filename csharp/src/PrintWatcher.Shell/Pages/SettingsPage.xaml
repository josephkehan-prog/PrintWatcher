<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource MutedBrush}" />
            <Setter Property="CharacterSpacing" Value="80" />
        </Style>
        <Style x:Key="GroupCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource PanelBrush}" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Padding" Value="20,16" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="20" MaxWidth="720" HorizontalAlignment="Left">
            <StackPanel Spacing="2">
                <TextBlock
                    Text="Settings"
                    FontSize="32"
                    FontWeight="Light"
                    Foreground="{ThemeResource TextBrush}" />
                <TextBlock
                    Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}"
                    Style="{StaticResource SectionLabelStyle}" />
            </StackPanel>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="THEME" Style="{StaticResource SectionLabelStyle}" />
                    <ComboBox
                        ItemsSource="{x:Bind ViewModel.ThemeKeys}"
                        SelectedItem="{x:Bind ViewModel.SelectedTheme, Mode=TwoWay}"
                        MinWidth="220" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="ACCESSIBILITY" Style="{StaticResource SectionLabelStyle}" />
                    <ToggleSwitch
                        Header="Larger text"
                        OffContent="Default"
                        OnContent="Scaled up by 1.15×"
                        IsOn="{x:Bind ViewModel.LargerText, Mode=TwoWay}" />
                    <ToggleSwitch
                        Header="Reduce transparency"
                        OffContent="Mica backdrop on"
                        OnContent="Solid surfaces only"
                        IsOn="{x:Bind ViewModel.ReduceTransparency, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Text="WATCHER" Style="{StaticResource SectionLabelStyle}" />
                    <ToggleSwitch
                        Header="Hold incoming files"
                        OffContent="Print as soon as files arrive"
                        OnContent="Hold for review on the Pending page"
                        IsOn="{x:Bind ViewModel.HoldMode, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GroupCardStyle}">
                <StackPanel Spacing="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="BACKEND LOG" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Show tail" Command="{x:Bind ViewModel.ShowBackendLogCommand}" />
                    </Grid>
                    <Border
                        Background="{ThemeResource LogBgBrush}"
                        CornerRadius="8"
                        Padding="12"
                        MinHeight="120"
                        MaxHeight="280">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{x:Bind ViewModel.BackendLog, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <TextBlock
                                            FontFamily="Consolas, Cascadia Code, monospace"
                                            FontSize="12"
                                            Foreground="{ThemeResource LogTextBrush}"
                                            Text="{x:Bind}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
