<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PrintWatcher.Shell.ViewModels"
    xmlns:controls="using:PrintWatcher.Shell.Controls"
    xmlns:svc="using:PrintWatcher.Shell.Services">
    <Page.Resources>
        <Style x:Key="StatTileStyle" TargetType="Border" BasedOn="{StaticResource CardSurfaceStyle}">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="92" />
        </Style>
        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="32,24,32,32" Spacing="20">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock
                        Text="PrintWatcher"
                        Style="{StaticResource PageTitleStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <controls:StatusPip
                            VerticalAlignment="Center"
                            IsActive="{x:Bind Negate(ViewModel.Paused), Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}"
                            FontSize="13"
                            Foreground="{ThemeResource MutedBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Content="{x:Bind ViewModel.PauseButtonLabel, Mode=OneWay}"
                    Command="{x:Bind ViewModel.TogglePauseCommand}"
                    MinWidth="100" />
            </Grid>

            <ItemsRepeater ItemsSource="{x:Bind StatTiles}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinItemWidth="170"
                        MinItemHeight="92"
                        MinRowSpacing="16"
                        MinColumnSpacing="16" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:StatTileItem">
                        <Border Style="{StaticResource StatTileStyle}" svc:GlassDepth.Elevated="True">
                            <StackPanel>
                                <TextBlock
                                    Text="{x:Bind Label}"
                                    Style="{StaticResource CaptionLabelStyle}" />
                                <TextBlock
                                    Text="{x:Bind Value, Mode=OneWay}"
                                    Style="{StaticResource StatNumberStyle}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <controls:OptionsPanel />

            <Border
                Style="{StaticResource CardSurfaceStyle}"
                Background="{ThemeResource LogBgBrush}"
                svc:GlassDepth.Elevated="True"
                Padding="16"
                MinHeight="280">
                <StackPanel Spacing="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="ACTIVITY"
                            Style="{StaticResource CaptionLabelStyle}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="Drop files anywhere on this page to print"
                            Style="{StaticResource CaptionLabelStyle}" />
                    </Grid>
                    <ListView
                        ItemsSource="{x:Bind ViewModel.Log}"
                        SelectionMode="None"
                        IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0,2" />
                                <Setter Property="MinHeight" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:LogLine">
                                <TextBlock
                                    Style="{StaticResource MonospaceTextStyle}"
                                    Text="{x:Bind Line}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
