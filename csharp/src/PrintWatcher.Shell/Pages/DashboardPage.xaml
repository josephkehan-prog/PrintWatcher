<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:PrintWatcher.Shell.ViewModels"
    xmlns:controls="using:PrintWatcher.Shell.Controls">
    <Page.Resources>
        <Style x:Key="StatTileStyle" TargetType="Border" BasedOn="{StaticResource GroupCardStyle}">
            <Setter Property="MinWidth" Value="160" />
            <Setter Property="MinHeight" Value="92" />
        </Style>
        <Style x:Key="StatNumberStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{ThemeResource TextBrush}" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PageContentPadding}" Spacing="20">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock
                        Text="PrintWatcher"
                        Style="{StaticResource PageTitleStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <controls:StatusPip
                            VerticalAlignment="Center"
                            IsActive="{x:Bind Negate(ViewModel.Paused), Mode=OneWay}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}"
                            FontSize="13"
                            Foreground="{ThemeResource MutedBrush}"
                            VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
                <Button
                    Grid.Column="1"
                    Content="{x:Bind ViewModel.PauseButtonLabel, Mode=OneWay}"
                    Command="{x:Bind ViewModel.TogglePauseCommand}"
                    MinWidth="100" />
            </Grid>

            <ItemsRepeater ItemsSource="{x:Bind StatTiles}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinItemWidth="170"
                        MinItemHeight="92"
                        MinRowSpacing="16"
                        MinColumnSpacing="16" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:StatTileItem">
                        <Border Style="{StaticResource StatTileStyle}">
                            <StackPanel>
                                <TextBlock
                                    Text="{x:Bind Label}"
                                    Style="{StaticResource SectionLabelStyle}" />
                                <TextBlock
                                    Text="{x:Bind Value, Mode=OneWay}"
                                    Style="{StaticResource StatNumberStyle}" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <controls:OptionsPanel />

            <!--
              Inbox health card. Shows OneDrive folder usage + per-bucket
              counts. Skipped count goes red when > 0 to surface stale
              files that need triage.
            -->
            <Border Style="{StaticResource GroupCardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock Text="INBOX" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.InboxHealth.WatchDir, Mode=OneWay}"
                            Foreground="{ThemeResource MutedBrush}"
                            TextTrimming="CharacterEllipsis"
                            FontSize="12" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock Text="USED" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.InboxBytesLabel, Mode=OneWay}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="2">
                        <TextBlock Text="PRINTED" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.InboxHealth.PrintedCount, Mode=OneWay}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextBrush}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="2">
                        <TextBlock Text="SKIPPED" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock
                            Text="{x:Bind ViewModel.SkippedLabel, Mode=OneWay}"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource ErrBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Background="{ThemeResource LogBgBrush}"
                CornerRadius="{StaticResource CardRadius}"
                Padding="16"
                MinHeight="280">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="ACTIVITY"
                            Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="Drop files anywhere on this page to print"
                            Style="{StaticResource SectionLabelStyle}" />
                    </Grid>
                    <Grid Grid.Row="1">
                        <ListView
                            x:Name="ActivityLog"
                            ItemsSource="{x:Bind ViewModel.Log}"
                            SelectionMode="None"
                            IsItemClickEnabled="False"
                            Visibility="{x:Bind LogToVisible(ViewModel.Log.Count), Mode=OneWay}">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0,2" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:LogLine">
                                    <TextBlock
                                        Style="{StaticResource LogTextStyle}"
                                        Text="{x:Bind Line}" />
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <TextBlock
                            Text="No activity yet. Drop a file or wait for the watcher to pick something up."
                            Style="{StaticResource SectionLabelStyle}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            TextAlignment="Center"
                            TextWrapping="Wrap"
                            MaxWidth="420"
                            Visibility="{x:Bind LogToCollapsed(ViewModel.Log.Count), Mode=OneWay}" />
                    </Grid>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
