<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.PendingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PrintWatcher.Shell.Models"
    xmlns:svc="using:PrintWatcher.Shell.Services">

    <Grid Padding="32,24,32,32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock
                Text="Pending"
                Style="{StaticResource PageTitleStyle}" />
            <TextBlock
                Text="Files held back from printing. Release them all, or skip them into _skipped/."
                Style="{StaticResource CaptionLabelStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}"
                Style="{StaticResource CaptionLabelStyle}"
                VerticalAlignment="Center" />
            <Button
                Grid.Column="1"
                Content="Refresh"
                Command="{x:Bind ViewModel.RefreshCommand}" />
            <Button
                Grid.Column="2"
                Content="Print all"
                Style="{ThemeResource AccentButtonStyle}"
                Command="{x:Bind ViewModel.PrintAllCommand}" />
            <Button
                Grid.Column="3"
                Content="Skip all"
                Command="{x:Bind ViewModel.SkipAllCommand}" />
        </Grid>

        <Border
            Grid.Row="2"
            Style="{StaticResource CardSurfaceStyle}"
            Background="{ThemeResource LogBgBrush}"
            svc:GlassDepth.Elevated="True"
            Padding="0">
            <Grid>
                <ListView
                    ItemsSource="{x:Bind ViewModel.Items}"
                    SelectionMode="Single"
                    Visibility="{x:Bind EmptyToCollapsed(ViewModel.IsEmpty), Mode=OneWay}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:PendingItemDto">
                            <StackPanel Padding="16,8" Spacing="2">
                                <TextBlock
                                    Text="{x:Bind Name}"
                                    Foreground="{ThemeResource TextBrush}" />
                                <TextBlock
                                    Text="{x:Bind Path}"
                                    Style="{StaticResource CaptionLabelStyle}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock
                    Text="No files pending. Anything dropped in your inbox while hold-mode is on will appear here."
                    Style="{StaticResource CaptionLabelStyle}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Padding="32"
                    TextAlignment="Center"
                    TextWrapping="Wrap"
                    MaxWidth="420"
                    Visibility="{x:Bind EmptyToVisible(ViewModel.IsEmpty), Mode=OneWay}" />
            </Grid>
        </Border>
    </Grid>
</Page>
