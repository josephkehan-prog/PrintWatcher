<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PrintWatcher.Shell.Models">
    <Page.Resources>
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource MutedBrush}" />
            <Setter Property="CharacterSpacing" Value="80" />
        </Style>
    </Page.Resources>

    <Grid Padding="32,24,32,32" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock
                Text="History"
                FontSize="32"
                FontWeight="Light"
                Foreground="{ThemeResource TextBrush}" />
            <TextBlock
                Text="{x:Bind ViewModel.StatusLabel, Mode=OneWay}"
                Style="{StaticResource SectionLabelStyle}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox
                Grid.Column="0"
                PlaceholderText="Filter (substring or /regex/)"
                Text="{x:Bind ViewModel.Filter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <CheckBox
                Grid.Column="1"
                Content="Regex"
                IsChecked="{x:Bind ViewModel.UseRegex, Mode=TwoWay}"
                VerticalAlignment="Center" />
            <Button
                Grid.Column="2"
                Content="Refresh"
                Command="{x:Bind ViewModel.RefreshCommand}" />
            <Button
                Grid.Column="3"
                Content="Clear all"
                Command="{x:Bind ViewModel.ClearCommand}" />
        </Grid>

        <Border
            Grid.Row="2"
            Background="{ThemeResource LogBgBrush}"
            CornerRadius="14"
            Padding="0">
            <ListView
                ItemsSource="{x:Bind ViewModel.Rows}"
                SelectionMode="Single">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="16,8" ColumnSpacing="8" Background="{ThemeResource PanelBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="TIME"      Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Grid.Column="1" Text="FILE"      Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Grid.Column="2" Text="STATUS"    Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Grid.Column="3" Text="SUBMITTER" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Grid.Column="4" Text="PRINTER"   Style="{StaticResource SectionLabelStyle}" />
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:PrintRecordDto">
                        <Grid Padding="16,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="180" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{x:Bind Timestamp}" FontFamily="Consolas, Cascadia Code, monospace" />
                            <TextBlock Grid.Column="1" Text="{x:Bind Filename}"  TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="2" Text="{x:Bind Status}" />
                            <TextBlock Grid.Column="3" Text="{x:Bind Submitter}" />
                            <TextBlock Grid.Column="4" Text="{x:Bind Printer}"   TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
