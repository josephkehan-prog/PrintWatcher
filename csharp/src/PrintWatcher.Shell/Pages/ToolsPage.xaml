<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PrintWatcher.Shell.Pages.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PrintWatcher.Shell.Controls"
    xmlns:vm="using:PrintWatcher.Shell.ViewModels">
    <Page.Resources>
        <Style x:Key="ToolCardStyle" TargetType="Border" BasedOn="{StaticResource GroupCardStyle}">
            <Setter Property="MinHeight" Value="140" />
        </Style>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="{StaticResource PageContentPadding}" Spacing="20">
            <controls:PageHeader
                Title="Tools"
                Subtitle="{x:Bind ViewModel.StatusLabel, Mode=OneWay}" />

            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Tools}">
                <ItemsRepeater.Layout>
                    <UniformGridLayout
                        MinItemWidth="280"
                        MinItemHeight="140"
                        MinRowSpacing="16"
                        MinColumnSpacing="16" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="vm:ToolDescriptor">
                        <Border Style="{StaticResource ToolCardStyle}">
                            <Grid RowSpacing="8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Text="{x:Bind Label}"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Foreground="{ThemeResource TextBrush}" />
                                <TextBlock
                                    Grid.Row="1"
                                    Text="{x:Bind Description}"
                                    Foreground="{ThemeResource MutedBrush}"
                                    TextWrapping="Wrap" />
                                <Button
                                    Grid.Row="2"
                                    Content="Run"
                                    Command="{x:Bind RunCommand}"
                                    HorizontalAlignment="Right" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </StackPanel>
    </ScrollViewer>
</Page>
